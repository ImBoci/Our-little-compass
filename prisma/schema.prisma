generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Couple {
  id          String    @id @default(uuid())
  inviteCode  String    @unique
  name        String?
  anniversary DateTime?

  users         User[]
  foods         Food[]
  activities    Activity[]
  memories      Memory[]
  shoppingItems ShoppingItem[]
  pets          Pet[]
  pushSubs      PushSubscription[]
  notifications AppNotification[]
}

model User {
  id       String  @id @default(uuid())
  name     String?
  email    String  @unique
  password String

  coupleId String?
  couple   Couple? @relation(fields: [coupleId], references: [id], onDelete: Cascade)
}

model Pet {
  id        String   @id @default(uuid())
  name      String
  type      String?  // e.g. "Cat", "Dog"
  startDate DateTime @default(now())
  
  coupleId  String
  couple    Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
}

model Food {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String?
  image_url   String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  coupleId    String
  couple      Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
}

model Activity {
  id          Int     @id @default(autoincrement())
  name        String
  description String?
  location    String?
  type        String?
  image_url   String?

  coupleId    String
  couple      Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
}

model Memory {
  id          Int      @id @default(autoincrement())
  name        String
  type        String
  date        DateTime @default(now())
  rating      Int
  note        String?
  image_url   String?
  user        String?

  coupleId    String
  couple      Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  user      String   // Name of the person (e.g., "Dani" or "Viki")
  payload   String   // The subscription JSON string
  createdAt DateTime @default(now())

  coupleId  String
  couple    Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
}

model AppNotification {
  id        Int      @id @default(autoincrement())
  title     String
  body      String
  sender    String
  createdAt DateTime @default(now())

  coupleId  String
  couple    Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
}

model ShoppingItem {
  id        Int      @id @default(autoincrement())
  name      String
  user      String?
  checked   Boolean  @default(false)
  createdAt DateTime @default(now())

  coupleId  String
  couple    Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
}